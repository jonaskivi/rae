# Owning-let `own a`: moves rather than copies. The destination
# binding takes ownership of a's buffer; a is marked moved so the
# scope-exit auto-drop skips it. No extra allocation, no double
# free.
import core
import sys

func main() {
  let a: List(Int) = createList(Int, cap: 4)
  a.add(value: 1)
  a.add(value: 2)
  a.add(value: 3)
  let b: List(Int) = own a
  log("b.length = {b.length}")
  log("b[0] = {b.get(index: 0)}")
}
