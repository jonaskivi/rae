# Smoke test for the GLFW wait-events bindings:
#   waitEventsTimeout(seconds: Float)
#   waitEvents()
#   postEmptyEvent()
#
# We only exercise waitEventsTimeout with a tiny timeout (50 ms) so the
# test stays fast; calling waitEvents() without a posted event would
# block forever in the runner. The point is just to confirm the
# binding compiles and links on both Live and Compiled targets and
# returns when the timeout elapses.
import core
open raylib

func main() {
    initWindow(width: 100, height: 100, title: "wait-events-smoke")
    waitEventsTimeout(seconds: 0.05)
    closeWindow()
    log("ok")
}
