import "math"

func main() {
  # Int overloads
  log("min(3, 7): {min(3, b: 7)}")
  log("max(3, 7): {max(3, b: 7)}")
  log("clamp(15, 0, 10): {clamp(15, low: 0, high: 10)}")
  log("clamp(-5, 0, 10): {clamp(-5, low: 0, high: 10)}")
  log("abs(-12): {abs(-12)}")

  # Float overloads (newly added)
  log("min(1.5, 2.5): {min(1.5, b: 2.5)}")
  log("max(1.5, 2.5): {max(1.5, b: 2.5)}")
  log("clamp(0.5, 1.0, 2.0): {clamp(0.5, low: 1.0, high: 2.0)}")
  log("clamp(2.5, 1.0, 2.0): {clamp(2.5, low: 1.0, high: 2.0)}")
  log("abs(-3.25): {abs(-3.25)}")

  log("lerp(0.0, 10.0, 0.5): {lerp(a: 0.0, b: 10.0, t: 0.5)}")
}
