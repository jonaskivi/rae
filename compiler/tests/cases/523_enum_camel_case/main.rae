import core
enum RenderMode {
    wireframe
    solid
    pathTraced
}
func name(m: view Int) ret String {
    match m {
        case RenderMode.wireframe {
            ret "wire"
        }
        case RenderMode.solid {
            ret "solid"
        }
        case RenderMode.pathTraced {
            ret "path"
        }
    }
}
func main() {
    let m = RenderMode.pathTraced
    log(name(m: m))
}
