func main() {
  let xs: List(Int) = createList(initialCap: 4)
  add(this: xs, value: 1)
  add(this: xs, value: 2)
  add(this: xs, value: 3)
  add(this: xs, value: 4)

  log("isEmpty: {isEmpty(this: xs)}")

  reverse(this: xs)
  log("reversed length: {xs.length}")
  log("first after reverse: {get(this: xs, index: 0)}")
  log("last after reverse: {get(this: xs, index: 3)}")

  let empty: List(Int) = createList(initialCap: 1)
  log("empty isEmpty: {isEmpty(this: empty)}")
}
