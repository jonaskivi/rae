func main() {
  let xs: List(Int) = createList(initialCap: 4)
  add(this: xs, value: 1)
  add(this: xs, value: 2)
  add(this: xs, value: 3)
  add(this: xs, value: 4)

  log("isEmpty: {isEmpty(this: xs)}")
  log("contains 3: {contains(this: xs, value: 3)}")
  log("contains 9: {contains(this: xs, value: 9)}")
  log("indexOf 2: {indexOf(this: xs, value: 2)}")
  log("indexOf 99: {indexOf(this: xs, value: 99)}")

  reverse(this: xs)
  log("reversed length: {xs.length}")
  log("first after reverse: {get(this: xs, index: 0)}")
  log("last after reverse: {get(this: xs, index: 3)}")

  let empty: List(Int) = createList(initialCap: 1)
  log("empty isEmpty: {isEmpty(this: empty)}")

  # Same overload names also exist on String — receiver-typed dispatch
  # picks the right implementation.
  let s: String = "hello"
  let needleLL: String = "ll"
  let needleL: String = "l"
  log("string contains ll: {contains(this: s, sub: needleLL)}")
  log("string indexOf l: {indexOf(this: s, sub: needleL)}")
}
