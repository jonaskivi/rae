# Test B from the ECS API redesign: componentView returns a borrowed
# reference into the table's storage, not a shallow-copy alias. The
# binding type `view T` prevents auto-drop and prevents the
# heap-corruption that the old `componentGet(...) ret T` shape could
# cause for heap-owning component types (Children has a List(Int)).
#
# Successful run prints the three ids twice (once via componentView,
# once via direct world access) and exits cleanly. A regression
# would either print junk on the second read (corruption) or crash
# on exit (double-free of the inner List buffer).
import core
import string
import ui/ecs
import ui/components

func main() {
  let world: UiWorld = createUiWorld()
  let parent: Int = createEntity(world: world)

  let kids: List(Int) = createList(Int, initialCap: 3)
  kids.add(value: 100)
  kids.add(value: 200)
  kids.add(value: 300)

  # Build Children in place so the heap is genuinely owned by the
  # struct literal, then transfer ownership of `kids` into the field.
  let ch: Children = { ids: own kids }
  componentSet(this: world.childrens, entity: parent, data: own ch)

  # Read back via componentView — borrow, no copy, no auto-drop.
  let chv: view Children => componentView(this: world.childrens, entity: parent)
  log("via componentView:")
  log("  [0]={chv.ids.get(index: 0)}")
  log("  [1]={chv.ids.get(index: 1)}")
  log("  [2]={chv.ids.get(index: 2)}")

  # Second read pretending we lost the first ref — value should still
  # be intact (no corruption from the first borrow going out of scope).
  let chv2: view Children => componentView(this: world.childrens, entity: parent)
  log("second read:")
  log("  [0]={chv2.ids.get(index: 0)}")
  log("  [1]={chv2.ids.get(index: 1)}")
  log("  [2]={chv2.ids.get(index: 2)}")
}
