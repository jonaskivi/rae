# Stage 8 + `+` operator coverage: every Stage 7 ret-epilogue for a
# String return now ends in `pool_register_owned(__ret_val)`, so
# String-returning calls that are used as arguments to other
# String-returning calls get cleaned up by the caller's surrounding
# mark/flush. This test also covers the user-facing `+` operator on
# String which lowers to the same rae_ext_rae_str_concat /
# rae_str_concat path that `.concat(other: ...)` uses.
import core
import string
import sys

# Case 1: simplest `+`
func plus2(a: view String, b: view String) ret String {
  ret a + b
}

# Case 2: nested 2-level `+`
func plus3(a: view String, b: view String, c: view String) ret String {
  ret a + b + c
}

# Case 3: nested 3-level `+`
func plus4(a: view String, b: view String, c: view String, d: view String) ret String {
  ret a + b + c + d
}

# Case 4: literal-backed return — pool_register_owned guard must
# skip is_owned=0 so we don't push literal data into the pool.
func returnLiteral() ret String {
  ret "literal"
}

# Case 5: `.concat()` method still works and produces the same shape.
func concatMethod(a: view String, b: view String) ret String {
  ret a.concat(other: b)
}

# Case 6: struct field initialised from a String-returning `+` call.
type Holder {
  msg: String
}

func makeHolder(label: view String) ret Holder {
  let h: Holder = { msg: "prefix-" + label }
  ret h
}

func main() {
  # Case 1: `+` lowered to concat helper
  let s1: String = plus2(a: "Hello ", b: "World")
  log("plus2: {s1}")

  # Case 2: 2-level nested
  let s2: String = plus3(a: "1", b: "2", c: "3")
  log("plus3: {s2}")

  # Case 3: 3-level nested
  let s3: String = plus4(a: "a", b: "b", c: "c", d: "d")
  log("plus4: {s3}")

  # Case 4: literal-backed
  let s4: String = returnLiteral()
  log("literal: {s4}")

  # Case 5: `.concat()` equivalence
  let s5: String = concatMethod(a: "foo", b: "bar")
  log("concat: {s5}")

  # Case 6: struct field init from `+`
  let h: Holder = makeHolder(label: "X")
  log("holder: {h.msg}")

  # Case 7: `+` directly at call site (expr-stmt)
  log("expr: {plus2(a: "A", b: "B")}")

  # Case 8: `+` with toString in chain — the exact mobile-UI RGBA
  # pattern that motivated the whole investigation.
  let r: Int = 30
  let g: Int = 40
  let b: Int = 50
  let av: Int = 255
  let rgba: String = r.toString() + "," + g.toString() + "," + b.toString() + "," + av.toString()
  log("rgba: {rgba}")

  # Case 9: leak guard — 10k iterations of the nested `+` chain
  # must not show linear String growth.
  let baselineKb: Int = processRssKb()
  let iterations: Int = 10000
  let i: Int = 0
  loop i < iterations {
    let r2: Int = 30
    let g2: Int = 40
    let b2: Int = 50
    let a2: Int = 255
    let rgba2: String = r2.toString() + "," + g2.toString() + "," + b2.toString() + "," + a2.toString()
    i = i + 1
  }
  let growthKb: Int = processRssKb() - baselineKb
  log("iterations: {iterations}")
  if growthKb > 2000 {
    log("verdict: LEAK")
  } else {
    log("verdict: OK")
  }
}
