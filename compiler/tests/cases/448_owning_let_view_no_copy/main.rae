# Owning-let `view T => a`: borrow rather than copy. The view
# binding shares storage with the source; no extra allocation,
# no auto-drop on the view (the source owns).
import core
import sys

func main() {
  let a: List(Int) = createList(Int, initialCap: 4)
  a.add(value: 7)
  a.add(value: 8)
  let b: view List(Int) => a
  log("a.length = {a.length}")
  log("b.length = {b.length}")
  log("b[0] = {b.get(index: 0)}")
}
