# Generic Queue(T) — FIFO ordering, exercising user-defined generics with
# a different access pattern from the Stack(T) test.

type Queue(T) {
  data: List(T)
  head: Int
}

func createQueue(T)() ret Queue(T) {
  ret Queue(T) {
    data: createList(T)(initialCap: 4)
    head: 0
  }
}

func enqueue(T)(this: mod Queue(T), value: T) {
  add(this.data, value: value)
}

func dequeue(T)(this: mod Queue(T)) ret opt T {
  if this.head >= this.data.length {
    ret none
  }
  let v: opt T = get(this.data, index: this.head)
  this.head = this.head + 1
  ret v
}

func qsize(T)(this: view Queue(T)) ret Int {
  ret this.data.length - this.head
}

func main() {
  let q: Queue(Int) = createQueue(Int)()
  enqueue(q, value: 1)
  enqueue(q, value: 2)
  enqueue(q, value: 3)
  log("size: {qsize(q)}")
  log("first: {dequeue(q)}")
  log("second: {dequeue(q)}")
  log("size: {qsize(q)}")
  log("third: {dequeue(q)}")
  log("after-empty: {dequeue(q) is none}")
}
