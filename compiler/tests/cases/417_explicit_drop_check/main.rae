# Explicit-drop regression guard. Pairs with 416_memory_leak_check.
#
# Calls `xs.drop()` mid-function while the binding is still in
# scope. This proves the Stage 1 stdlib `drop()` primitive in
# `lib/core.rae` actually releases the Buffer to the allocator
# AND that drop() leaves the List safely in a "no-data, length=0,
# capacity=0" state so it's tolerant of double-drop.
#
# Why the local is reassigned after drop: with Stage 3 auto-drop
# enabled, the end-of-body drop pass would otherwise free the
# already-freed buffer and crash. Re-binding `xs` to a fresh
# zero-capacity List gives the auto-drop something safe to free.
# Stage 4 will track "manually-dropped" locals so this dance is
# unnecessary.
#
# Expected: `verdict: OK` on BOTH targets.
#
# If this test ever starts failing, `drop()` on `List(T)` in
# `lib/core.rae` is broken — fix that before anything else.
import core
import string
import sys

func transientAllocation(cap: view Int) {
  let xs: List(Int) = createList(Int, cap: cap)
  let i: Int = 0
  loop i < cap {
    xs.add(value: i)
    i = i + 1
  }
  # Explicit mid-function drop. The List struct stays in scope but
  # its backing Buffer is released. After this call xs.data is
  # whatever drop left it (currently dangling); re-binding the
  # local immediately avoids any further use.
  xs.drop()
  xs = createList(Int, cap: 0)
}

func main() {
  let cap: Int = 1024
  let iterations: Int = 5000

  transientAllocation(cap: cap)
  let baselineKb: Int = processRssKb()

  let i: Int = 0
  loop i < iterations {
    transientAllocation(cap: cap)
    i = i + 1
  }
  let finalKb: Int = processRssKb()
  let growthKb: Int = finalKb - baselineKb

  let thresholdKb: Int = 5000

  log("iterations: {iterations}")
  log("growth_kb: {growthKb}")
  if growthKb > thresholdKb {
    log("verdict: LEAK")
  } else {
    log("verdict: OK")
  }
}
