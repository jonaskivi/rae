# Phase 3: cascade drop of String fields inside user structs. Verifies
# that:
#
#   1. A struct-literal local with String fields gets its Strings
#      freed at scope exit (no leak across 10k iterations).
#   2. An alias-extracted struct (let v = buf_get(...)) does NOT
#      cascade-drop its Strings — the source buffer's storage stays
#      reachable, no double-free.
#   3. Stage-6 deep-copy accessors (returning a fresh owned struct)
#      get the full cascade drop, closing the Phase 2 deep-copy leak.
#
# Slope-based check: RSS growth across 10k iterations should be flat.
# Threshold tuned above OS bookkeeping noise but well under what an
# un-cascaded leak would produce (each iteration mallocs ~6 strings).
import core
import string
import sys

type Owned {
  a: String
  b: String
}

# Builds a fresh owned struct via struct literal. Phase 2 deep-copies
# the bare-ident RHS, Phase 3's full cascade then frees both copies
# at end of scope.
func buildOwned(srcA: own String, srcB: own String) ret Owned {
  ret Owned {
    a: srcA
    b: srcB
  }
}

# Each call: allocate the bare-ident strings (concat produces heap),
# build an owned struct (Phase 2 deep-copies both), let scope-exit
# cascade-drop run. With Phase 3 working the heap stays flat.
func iterOwned() {
  let a: String = "alpha-".concat(other: "leak-test")
  let b: String = "beta-".concat(other: "leak-test")
  let p: Owned = buildOwned(srcA: a, srcB: b)
  # Read both fields so the compiler can't dead-code the struct.
  if p.a.length() < 0 {
    log("never")
  }
  if p.b.length() < 0 {
    log("never")
  }
}

# Builds an Owned, passes it to a function that consumes ownership
# via plain-T parameter, and confirms move-tracking skips the auto-
# drop on the caller side (no double-free with the buf-stored copy).
func consumeOwned(p: own Owned) {
  if p.a.length() < 0 {
    log("never")
  }
}

func iterMove() {
  let p: Owned = { a: "alpha", b: "beta" }
  consumeOwned(p: p)
}

func main() {
  let warmups: Int = 50
  var i: Int = 0
  loop i < warmups {
    iterOwned()
    iterMove()
    i = i + 1
  }
  let baselineKb: Int = processRssKb()

  let iterations: Int = 10000
  i = 0
  loop i < iterations {
    iterOwned()
    iterMove()
    i = i + 1
  }
  let finalKb: Int = processRssKb()
  let growthKb: Int = finalKb - baselineKb

  log("iterations: {iterations}")
  if growthKb < 2000 {
    log("verdict: OK")
  } else {
    log("verdict: LEAK growth_kb={growthKb}")
  }
}
