# Strong reproduction of the view-String compound-literal torn-read
# regression that previously blocked sceneNodeIndex/parseScene/
# parseJson migration to `view String`. Mirrors scene_loader's
# pass-3 children loop exactly: Buffer-backed nodes, List<String>
# childIds per node, repeated view-String calls to a helper inside
# a loop, with sibling structs of different nodeId lengths.
#
# Pre-fix symptom (compound-literal view-wrap):
#   the temp's data ptr and length get read from different
#   compound-literal temps in the same enclosing block. Children
#   "TopBar" (len 6) gets the data pointer from a sibling's
#   "PlayBtn" — equals returns false even when the value should
#   match.
#
# Test asserts EXACT string identity, not just length.
import core
import string

type Node {
  nodeId: String
  childIds: List(String)
}

func nodeIndex(nodes: view List(Node), target: view String) ret Int {
  let n: Int = nodes.length
  let i: Int = 0
  loop i < n {
    let nd: Node = rae_ext_rae_buf_get(buf: nodes.data, index: i)
    if nd.nodeId.equals(other: target) {
      ret i
    }
    i = i + 1
  }
  ret -1
}

func main() {
  let nodes: List(Node) = createList(Node, initialCap: 8)

  # Build 5 nodes with siblings of different lengths to maximize
  # chance of torn-read pattern.
  let rootKids: List(String) = createList(String, initialCap: 4)
  rootKids.add(value: "TopBar")
  rootKids.add(value: "AlbumHero")
  rootKids.add(value: "PlayBtn")
  nodes.add(value: { nodeId: "AlbumRoot", childIds: own rootKids })

  let topKids: List(String) = createList(String, initialCap: 1)
  topKids.add(value: "BackBtn")
  nodes.add(value: { nodeId: "TopBar", childIds: own topKids })

  let backKids: List(String) = createList(String, initialCap: 0)
  nodes.add(value: { nodeId: "BackBtn", childIds: own backKids })

  let heroKids: List(String) = createList(String, initialCap: 0)
  nodes.add(value: { nodeId: "AlbumHero", childIds: own heroKids })

  let playKids: List(String) = createList(String, initialCap: 0)
  nodes.add(value: { nodeId: "PlayBtn", childIds: own playKids })

  # Build a parallel map of nodeId → index, mirroring world.nodeIds.
  let map: StringMap(Int) = createStringMap(Int, initialCap: 16)
  let s: Int = 0
  loop s < nodes.length {
    let nd: Node = rae_ext_rae_buf_get(buf: nodes.data, index: s)
    map.set(k: nd.nodeId, value: s)
    s = s + 1
  }

  # Pass mirroring scene_loader pass 3 EXACTLY: nested loop, view-
  # String helper, componentSet-like side effect, all in the same
  # enclosing block.
  let p: Int = 0
  loop p < nodes.length {
    let parent: Node = rae_ext_rae_buf_get(buf: nodes.data, index: p)
    let kn: Int = parent.childIds.length
    if kn > 0 {
      let kidsAssembly: List(Int) = createList(Int, initialCap: kn)
      let q: Int = 0
      loop q < kn {
        let childId: String = parent.childIds.get(index: q)
        # Two view-String calls per iter, mirroring the multiple-wrap
        # pattern (nodeIndex + map.get).
        let idx: Int = nodeIndex(nodes: nodes, target: childId)
        let entityOpt: opt Int = map.get(k: childId)
        let entityVal: Int = -1
        if entityOpt is not none {
          entityVal = entityOpt
        }
        log("parent={parent.nodeId} child=[{childId}] childLen={childId.length()} nodeIndex={idx} mapEntity={entityVal}")
        kidsAssembly.add(value: idx)
        q = q + 1
      }
    }
    p = p + 1
  }
}
