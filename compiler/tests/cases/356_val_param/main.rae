type Large {
  a: Int
  b: Int
  c: Int
}

# `copy T` (the modern replacement for the deprecated `val T`)
# gives the callee an independent deep-copy of the value.
func modifyCopy(l: copy Large) {
  log("inside modifyCopy l.a: {l.a}")
}

# Explicit view borrow — the original Large stays alive in the caller.
func modifyView(l: view Large) {
  # l.a = 888 # ERROR: view is read-only
  log("inside modifyView l.a: {l.a}")
}

func main() {
  let l: Large = { a: 1, b: 2, c: 3 }
  log("before modifyCopy l.a: {l.a}")
  modifyCopy(l)
  log("after modifyCopy l.a: {l.a}")

  modifyView(l)
}
