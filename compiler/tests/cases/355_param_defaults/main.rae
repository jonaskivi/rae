type Point {
  x: Int
  y: Int
}

# view by default (implicit when an explicit mode is used) — bare T
# is rejected at sema; tests below all use explicit modes.
func testView(p: view Point) {
  log("testView x: {p.x}")
  # p.x = 10 # Error: p is view
}

# Explicit view
func testExplicitView(p: view Point) {
  log("testExplicitView x: {p.x}")
}

# mod reference
func testMod(p: mod Point) {
  p.x = p.x + 1
  log("testMod x: {p.x}")
}

# copy (deep-copy of the value — callee owns an independent copy)
func testCopy(p: copy Point) {
  log("testCopy x: {p.x}")
}

# Primitive view (passed by value internally but semantically view)
func testInt(i: view Int) {
  log("testInt: {i}")
}

func main() {
  let pt: Point = { x: 1, y: 2 }

  testView(pt)
  testExplicitView(pt)

  testMod(mod pt)
  log("after mod pt.x: {pt.x}")

  testCopy(pt)
  log("after copy pt.x: {pt.x}")

  testInt(42)
}
