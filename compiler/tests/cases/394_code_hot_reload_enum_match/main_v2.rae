enum Color {
  Red
  Green
  Blue
}

func describe(c: Int) ret String {
  match c {
    case Color.Red {
      ret "v2: R"
    }
    case Color.Green {
      ret "v2: G"
    }
    case Color.Blue {
      ret "v2: B"
    }
  }
  ret "unknown"
}

func main() {
  loop true {
    tick()
    sleep(ms: 500)
  }
}

func tick() {
  log(describe(c: Color.Green))
}
