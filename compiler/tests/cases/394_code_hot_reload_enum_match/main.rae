enum Color {
  Red
  Green
  Blue
}

func describe(c: view Int) ret String {
  match c {
    case Color.Red {
      ret "v1: red"
    }
    case Color.Green {
      ret "v1: green"
    }
    case Color.Blue {
      ret "v1: blue"
    }
  }
  ret "unknown"
}

func main() {
  loop true {
    tick()
    sleep(ms: 500)
  }
}

func tick() {
  log(describe(c: Color.Green))
}
