enum Color {
  red
  green
  blue
}

func describe(c: view Int) ret String {
  match c {
    case Color.red {
      ret "v1: red"
    }
    case Color.green {
      ret "v1: green"
    }
    case Color.blue {
      ret "v1: blue"
    }
  }
  ret "unknown"
}

func main() {
  loop true {
    tick()
    sleep(ms: 500)
  }
}

func tick() {
  log(describe(c: Color.green))
}
