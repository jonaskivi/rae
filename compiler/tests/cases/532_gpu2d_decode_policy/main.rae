# #228 (design #217): gpu2d image decode error policy. Decode is
# strict magic-byte dispatch (vendored stb_image for JPEG, lodepng
# for PNG), no fallback cascade; failures log ONE stderr line and
# yield 0 (loadImage then returns handle 0 and callers render their
# placeholder). The probe extern runs the exact loadImage decode
# path without a WebGPU device.
#
# Success paths (real JPEG via stb, real PNG via lodepng) are proven
# by the 106_mobile_ui headless screenshot runs — this case pins the
# FAILURE policy, which needs no assets and no cwd assumptions.
# Compiled-target only (the extern has no Live VM binding).
import core
import gpu2d

func rae_ext_rae_sys_write_file(path: String, content: String) extern ret Bool

func main() {
  # Garbage bytes with a .jpg name: no JPEG/PNG magic -> unsupported,
  # decode fails cleanly (no cascade into another decoder).
  let junkPath: String = "/tmp/rae_532_junk.jpg"
  let wrote: Bool = rae_ext_rae_sys_write_file(path: junkPath, content: "definitely not an image")
  let okJunk: Int = gpu2d.decodeImageProbe(path: junkPath)
  log("junk wrote={wrote} decode={okJunk}")

  # Missing file -> unreadable, decode fails cleanly.
  let okMissing: Int = gpu2d.decodeImageProbe(path: "/tmp/rae_532_missing.xyz")
  log("missing decode={okMissing}")
}
