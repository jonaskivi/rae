# Stage 4 leak guard: heap String temporaries produced by
# interpolation must be dropped at end-of-statement, not leaked.
#
# Before Stage 4 every interpolation chain leaked the intermediate
# concat allocations plus the toString conversion result. Over a
# 10000-iteration loop the leak was clearly visible in RSS.
#
# This guards both the interpolation case (passed to log) and the
# concat-temp case (used to build a captured String via `+`-style
# chains lowered to nested str_concat calls).
import core
import sys

func work(i: view Int) {
  # Bind interp result into a String local. Captured by the let,
  # so the binding takes ownership from the pool and the
  # statement-end flush doesn't free it. Local goes out of scope
  # at the next iteration without leaking.
  let label: String = "row-{i}"
}

func main() {
  # Warm up so initial allocator pages don't show up as growth.
  var warmupI: Int = 0
  loop warmupI < 100 {
    work(i: warmupI)
    warmupI = warmupI + 1
  }

  let baselineKb: Int = processRssKb()
  let iterations: Int = 10000
  var i: Int = 0
  loop i < iterations {
    work(i: i)
    i = i + 1
  }
  let growthKb: Int = processRssKb() - baselineKb
  log("iterations: {iterations}")
  if growthKb > 2000 {
    log("verdict: LEAK")
  } else {
    log("verdict: OK")
  }
}
