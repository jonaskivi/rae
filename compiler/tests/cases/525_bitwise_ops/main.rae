# Bitwise word operators (bitand/bitor/bitxor/bitnot/shl/shr), Int-only.
# Logical and/or stay boolean; these produce Int. Bitwise binds tighter than
# arithmetic and comparison; mixing different bitwise ops needs parens.
import core

func main() {
    let a: Int = 12   # 1100
    let b: Int = 10   # 1010
    log(a bitand b)     # 8
    log(a bitor b)      # 14
    log(a bitxor b)     # 6
    log(1 shl 8)      # 256
    log(256 shr 2)    # 64
    log(bitnot 0)       # -1
    # bitand binds tighter than `is`
    if 511 bitand 255 is 255 { log(1) } else { log(0) }   # 1
    # parenthesised shifts compose (the 0xRRGGBB packing pattern)
    log((200 shl 16) bitor (100 shl 8) bitor 50)            # 13132850
    # bitwise binds tighter than +: 1 + (2 shl 4)
    log(1 + 2 shl 4)                                     # 33
}
