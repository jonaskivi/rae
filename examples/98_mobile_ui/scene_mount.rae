# Scene-mount helpers with a visible-failure sentinel. `mountOrError`
# wraps `mountSceneInstance` so a `-1` return (parse failure, missing
# root, etc.) turns into a bright red rectangle on screen plus a log
# entry — instead of producing a half-built subtree that renders as
# the background clear color (the "grey screen of death").
import core
import string
import ui/components
import ui/ecs
import ui/registry
import ui/scene
import ui/scene_instance

# Decorate `entity` as a glaring red error block with a label. Used
# when scene mounting fails. Caller has already set the entity's Rect/Size.
func paintErrorBlock(world: mod UiWorld, entity: view EntityId, label: view String) pub {
  let red: RgbaColor = { r: 220, g: 32, b: 48, a: 255 }
  let shape: Shape = {
    kind: ShapeKind.RoundedRect
    fill: red
    stroke: RgbaColor { r: 0, g: 0, b: 0, a: 0 }
    strokeWidth: 0.0
    radius: 8.0
  }
  componentSet(this: world.shapes, entity: entity, data: shape)

  let txt: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: txt, w: 480.0, h: 32.0)
  let prefix: String = "Scene mount failed: "
  let msg: String = prefix.concat(other: label)
  setText(world: world, entity: txt, text: msg, styleId: "primary")

  let kids: List(EntityId) = createList(EntityId, initialCap: 1)
  kids.add(value: txt)
  attachChildren(world: world, parent: entity, kids: kids)
}

# Mount a scene under `mountEntity`. On failure log + paint the entity
# as a sentinel error block and return the mount entity (callers expect
# a non-negative id).
func mountOrError(
  world: mod UiWorld
  mountEntity: view EntityId
  scene: view Scene
  sceneLabel: view String
  overrides: view List(SceneOverride)
) pub ret EntityId {
  let result: EntityId = mountSceneInstance(
    world: world
    mountEntity: mountEntity
    scene: scene
    overrides: overrides
  )
  if isNone(this: result) {
    let label: String = sceneLabel
    log("[scene-error] mount failed for {label} (entity {mountEntity.value}, scene.ok={scene.ok}, scene.errorMsg={scene.errorMsg})")
    paintErrorBlock(world: world, entity: mountEntity, label: label)
    ret mountEntity
  }
  ret result
}

# Mount a scene under a fresh entity sized w x h. No overrides. `label`
# is a short human-readable name used in error logs / on the sentinel
# error block when mounting fails.
func buildSimpleSceneInstance(
  world: mod UiWorld
  scene: view Scene
  w: view Float
  h: view Float
  label: view String
) pub ret EntityId {
  let mount: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: mount, w: w, h: h)
  let noOverrides: List(SceneOverride) = emptyOverrides()
  let mounted: EntityId = mountOrError(
    world: world
    mountEntity: mount
    scene: scene
    sceneLabel: label
    overrides: noOverrides
  )
  ret mount
}

# mountPage wrapper with the same visible-failure-sentinel behaviour
# as `mountOrError`: on a parse / root-missing failure we still
# materialise a host entity at the requested size, paint it red, and
# tag it with PageRoot so the id is discoverable. Returns the page
# root entity in both the success and the failure case.
func mountPageOrError(
  world: mod UiWorld
  pageId: own String
  scene: view Scene
  overrides: view List(SceneOverride)
  w: view Float
  h: view Float
  sceneLabel: view String
) pub ret EntityId {
  let root: EntityId = mountPage(
    world: world
    pageId: pageId
    scene: scene
    overrides: overrides
    w: w
    h: h
  )
  if isNone(this: root) is false {
    ret root
  }
  # Build a husk: same shape as the success path, plus the red error
  # block + PageRoot tag.
  let husk: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: husk, w: w, h: h)
  let label: String = sceneLabel
  log("[scene-error] mount failed for page {pageId} (scene.ok={scene.ok}, scene.errorMsg={scene.errorMsg})")
  paintErrorBlock(world: world, entity: husk, label: label)
  let copiedId: String = ""
  copiedId = copiedId.concat(other: pageId)
  let pr: PageRoot = { id: own copiedId }
  componentSet(this: world.pageRoots, entity: husk, data: own pr)
  ret husk
}
