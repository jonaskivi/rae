# Profile-tab world composition. The user-account screen:
#   * top bar "Profile"
#   * circular avatar
#   * display name + bio
#   * Spotify-connection card — live status of the remote player
#     ("Playing 'Track' by 'Artist'", "Paused", or "Not connected")
#   * three small stat columns (library counts, total tracks, etc.)
#   * settings list — placeholder rows with chevrons
#
# This used to be the same screen as Library (one big "profile +
# albums" pile). The catalogue is its own Library tab now; this
# screen is purely about the user and their connection to Spotify.
#
# Like the Library page, the body owns a `ScrollState` so the
# settings list can scroll if it overflows.
import core
import fs
import sys/spotify
import ui/components
import ui/ecs
import ui/layout

# Local circle shape helper — world_helpers.rae only exposes rect /
# rounded-rect variants; the avatar needs a true `ShapeKind.Circle`.
func setProfileCircleShape(world: mod UiWorld, entity: view EntityId, fill: view RgbaColor) {
  let sh: Shape = {
    kind: ShapeKind.Circle
    fill: fill
    stroke: RgbaColor { r: 0, g: 0, b: 0, a: 0 }
    strokeWidth: 0.0
    radius: 0.0
  }
  componentSet(this: world.shapes, entity: entity, data: sh)
}

let profileAvatarSize: Float = 120.0
let profileAvatarIconSize: Float = 80.0

func buildProfileAvatar(world: mod UiWorld, reg: view TextureRegistry) ret EntityId {
  let avatar: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: avatar, w: profileAvatarSize, h: profileAvatarSize)

  let avatarKey: String = profileAvatarKey()
  if textureHas(reg: reg, key: avatarKey) {
    # Real profile picture — circle-cropped at load time
    # (`loadCircleCroppedTexture`). The alpha mask on the underlying
    # texture handles the round shape; no background Shape needed.
    let whiteTint: RgbaColor = { r: 255, g: 255, b: 255, a: 255 }
    setSprite(world: world, entity: avatar, key: avatarKey, tint: whiteTint)
  } else {
    let accentBg: RgbaColor = darkPillColor
    setProfileCircleShape(world: world, entity: avatar, fill: accentBg)
    let layS: LayoutType = LayoutType.Stack
    let alignC: AlignKind = AlignKind.Center
    setLayout(world: world, entity: avatar, kind: layS, gap: 0.0, alignCross: alignC)

    let icon: EntityId = createEntity(world: world)
    setRectFixed(world: world, entity: icon, w: profileAvatarIconSize, h: profileAvatarIconSize)
    let personKey: String = "mat:person"
    setSprite(world: world, entity: icon, key: personKey, tint: lightTextColor)

    let kids: List(EntityId) = createList(EntityId, cap: 1)
    kids.add(value: icon)
    attachChildren(world: world, parent: avatar, kids: kids)
  }
  ret avatar
}

# Stat column: big number on top, small label below.
func buildProfileStatColumn(world: mod UiWorld, value: own String, label: own String) ret EntityId {
  let col: EntityId = createEntity(world: world)
  let colW: Float = 110.0
  let colH: Float = 56.0
  setRectFixed(world: world, entity: col, w: colW, h: colH)
  let layV: LayoutType = LayoutType.Vertical
  let alignC: AlignKind = AlignKind.Center
  setLayout(world: world, entity: col, kind: layV, gap: 2.0, alignCross: alignC)

  let valueText: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: valueText, w: colW, h: 28.0)
  let valueStyle: String = "topBarTitle"
  setText(world: world, entity: valueText, text: value, styleId: valueStyle)

  let labelText: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: labelText, w: colW, h: 18.0)
  let labelStyle: String = "muted"
  setText(world: world, entity: labelText, text: label, styleId: labelStyle)

  let kids: List(EntityId) = createList(EntityId, cap: 2)
  kids.add(value: valueText)
  kids.add(value: labelText)
  attachChildren(world: world, parent: col, kids: kids)
  ret col
}

# Library-stats row. Pulls live counts from the album catalogue so the
# numbers stay honest — no fake follower counts.
func buildProfileStatsRow(world: mod UiWorld, state: view AppState) ret EntityId {
  let row: EntityId = createEntity(world: world)
  let rowW: Float = screenW - outerPad * 2.0
  let rowH: Float = 60.0
  setRectFixed(world: world, entity: row, w: rowW, h: rowH)
  let layH: LayoutType = LayoutType.Horizontal
  let alignC: AlignKind = AlignKind.Center
  setLayout(world: world, entity: row, kind: layH, gap: 24.0, alignCross: alignC)

  let albumCount: Int = state.albums.length
  let trackCount: Int = 0
  let totalMs: Int = 0
  let i: Int = 0
  loop i < albumCount {
    let a: Album = rae_ext_rae_buf_get(buf: state.albums.data, index: i)
    trackCount = trackCount + a.tracks.length
    totalMs = totalMs + a.totalDurationMs
    i = i + 1
  }
  let totalHours: Int = totalMs / 3600000
  let albumsStr: String = "{albumCount}"
  let tracksStr: String = "{trackCount}"
  let hoursStr: String = "{totalHours}h"
  let albumsLabel: String = "Albums"
  let tracksLabel: String = "Tracks"
  let hoursLabel: String = "Listening"

  let albumsCol: EntityId = buildProfileStatColumn(world: world, value: albumsStr, label: albumsLabel)
  let tracksCol: EntityId = buildProfileStatColumn(world: world, value: tracksStr, label: tracksLabel)
  let hoursCol: EntityId = buildProfileStatColumn(world: world, value: hoursStr, label: hoursLabel)

  let kids: List(EntityId) = createList(EntityId, cap: 3)
  kids.add(value: albumsCol)
  kids.add(value: tracksCol)
  kids.add(value: hoursCol)
  attachChildren(world: world, parent: row, kids: kids)
  ret row
}

# "Connected to Spotify" card. Shows live status from the C bridge so
# the user can confirm at a glance whether playback is routed to a
# real Spotify desktop session. Reads `RAE_UI_NO_SPOTIFY` directly
# rather than threading the flag through every builder.
func buildSpotifyStatusCard(world: mod UiWorld) ret EntityId {
  let optOut: String = getEnv(name: "RAE_UI_NO_SPOTIFY")
  let spotifyEnabled: Bool = optOut.length() is 0
  let card: EntityId = createEntity(world: world)
  let cardW: Float = screenW - outerPad * 2.0
  let cardH: Float = 84.0
  setRectFixed(world: world, entity: card, w: cardW, h: cardH)
  let bg: RgbaColor = { r: 30, g: 200, b: 130, a: 255 }
  setShapeRect(world: world, entity: card, fill: bg)
  let layV: LayoutType = LayoutType.Vertical
  let alignS: AlignKind = AlignKind.Start
  setLayout(world: world, entity: card, kind: layV, gap: 4.0, alignCross: alignS)
  setPaddingAll(world: world, entity: card, n: 14.0)

  let title: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: title, w: cardW - 28.0, h: 24.0)
  let titleStyle: String = "topBarTitle"
  let titleText: String = "Spotify"
  setText(world: world, entity: title, text: titleText, styleId: titleStyle)

  let line: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: line, w: cardW - 28.0, h: 22.0)
  let bodyStyle: String = "trackArtist"
  let line1: String = ""
  if spotifyEnabled is false {
    line1 = "Disabled (RAE_UI_NO_SPOTIFY=1)"
  } else {
    spotifyRefresh()
    let st: String = spotifyState()
    let playingKey: String = "playing"
    let pausedKey: String = "paused"
    if st.equals(other: playingKey) {
      let trk: String = spotifyTrackName()
      let art: String = spotifyArtistName()
      line1 = "Playing '{trk}' — {art}"
    } else {
      if st.equals(other: pausedKey) {
        line1 = "Paused"
      } else {
        line1 = "Not running"
      }
    }
  }
  setText(world: world, entity: line, text: line1, styleId: bodyStyle)

  let kids: List(EntityId) = createList(EntityId, cap: 2)
  kids.add(value: title)
  kids.add(value: line)
  attachChildren(world: world, parent: card, kids: kids)
  ret card
}

# One settings row — icon on the left, label center, chevron right.
# Inert for now (no actionId) — placeholder rows that visually
# complete the screen without pretending to work.
func buildSettingsRow(world: mod UiWorld, iconKey: own String, label: own String) ret EntityId {
  let row: EntityId = createEntity(world: world)
  let rowW: Float = screenW - outerPad * 2.0
  let rowH: Float = 56.0
  setRectFixed(world: world, entity: row, w: rowW, h: rowH)
  let layH: LayoutType = LayoutType.Horizontal
  let alignC: AlignKind = AlignKind.Center
  setLayout(world: world, entity: row, kind: layH, gap: 14.0, alignCross: alignC)
  setPaddingAll(world: world, entity: row, n: 8.0)

  let iconSize: Float = 28.0
  let icon: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: icon, w: iconSize, h: iconSize)
  setSprite(world: world, entity: icon, key: iconKey, tint: iconTint)

  let labelW: Float = rowW - iconSize - 14.0 - 24.0 - 14.0 - 16.0
  let labelEnt: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: labelEnt, w: labelW, h: 24.0)
  let labelStyle: String = "trackTitle"
  setText(world: world, entity: labelEnt, text: label, styleId: labelStyle)

  let chev: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: chev, w: 24.0, h: 24.0)
  let chevKey: String = "mat:chevron_right"
  let chevTint: RgbaColor = heroColor
  setSprite(world: world, entity: chev, key: chevKey, tint: chevTint)

  let kids: List(EntityId) = createList(EntityId, cap: 3)
  kids.add(value: icon)
  kids.add(value: labelEnt)
  kids.add(value: chev)
  attachChildren(world: world, parent: row, kids: kids)
  ret row
}

func buildSettingsList(world: mod UiWorld) ret EntityId {
  let list: EntityId = createEntity(world: world)
  let listW: Float = screenW - outerPad * 2.0
  let rowH: Float = 56.0
  let gap: Float = 4.0
  let rowCount: Int = 4
  let listH: Float = rowH * rowCount.toFloat() + gap * (rowCount - 1).toFloat()
  setRectFixed(world: world, entity: list, w: listW, h: listH)
  let layV: LayoutType = LayoutType.Vertical
  let alignS: AlignKind = AlignKind.Start
  setLayout(world: world, entity: list, kind: layV, gap: gap, alignCross: alignS)

  let r1: EntityId = buildSettingsRow(world: world, iconKey: "mat:tune", label: "Audio quality")
  let r2: EntityId = buildSettingsRow(world: world, iconKey: "mat:equalizer", label: "Equalizer")
  let r3: EntityId = buildSettingsRow(world: world, iconKey: "mat:person", label: "Account")
  let r4: EntityId = buildSettingsRow(world: world, iconKey: "mat:logout", label: "Sign out")

  let kids: List(EntityId) = createList(EntityId, cap: 4)
  kids.add(value: r1)
  kids.add(value: r2)
  kids.add(value: r3)
  kids.add(value: r4)
  attachChildren(world: world, parent: list, kids: kids)
  ret list
}

func buildProfileBody(
  world: mod UiWorld
  reg: view TextureRegistry
  state: view AppState
  scrollY: view Float
) ret EntityId {
  let body: EntityId = createEntity(world: world)
  let bodyW: Float = screenW - outerPad * 2.0
  let bodyH: Float = screenH - topBarH - navTabsH - outerGap * 4.0 - outerPad * 2.0
  setRectFixed(world: world, entity: body, w: bodyW, h: bodyH)
  let layV: LayoutType = LayoutType.Vertical
  let alignC: AlignKind = AlignKind.Center
  setLayout(world: world, entity: body, kind: layV, gap: outerGap, alignCross: alignC)
  let off: Offset = { delta: Vec2 { x: 0.0, y: scrollY } }
  componentSet(this: world.offsets, entity: body, data: off)

  let scroll: ScrollState = { y: scrollY, velocity: 0.0 }
  componentSet(this: world.scrollStates, entity: body, data: scroll)

  let avatar: EntityId = buildProfileAvatar(world: world, reg: reg)

  let handle: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: handle, w: bodyW, h: 28.0)
  let handleStyle: String = "topBarTitle"
  let handleText: String = "@violet.tapes"
  setText(world: world, entity: handle, text: handleText, styleId: handleStyle)

  let bio: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: bio, w: bodyW, h: 18.0)
  let bioStyle: String = "muted"
  let bioText: String = "indie pop · dream-punk · playlist lover"
  setText(world: world, entity: bio, text: bioText, styleId: bioStyle)

  let card: EntityId = buildSpotifyStatusCard(world: world)
  let stats: EntityId = buildProfileStatsRow(world: world, state: state)
  let settings: EntityId = buildSettingsList(world: world)

  let kids: List(EntityId) = createList(EntityId, cap: 6)
  kids.add(value: avatar)
  kids.add(value: handle)
  kids.add(value: bio)
  kids.add(value: card)
  kids.add(value: stats)
  kids.add(value: settings)
  attachChildren(world: world, parent: body, kids: kids)
  ret body
}

# Persistent-world entrypoint. Mounts the profile page into `world`
# and returns the page-root entity. Tagged with `PageRoot{profilePageId}`.
func mountProfilePage(
  world: mod UiWorld
  reg: view TextureRegistry
  state: view AppState
  scrollY: view Float
) pub ret EntityId {
  let root: EntityId = createEntity(world: world)
  setRectFixed(world: world, entity: root, w: screenW, h: screenH)
  let layV: LayoutType = LayoutType.Vertical
  let alignS: AlignKind = AlignKind.Start
  setLayout(world: world, entity: root, kind: layV, gap: outerGap, alignCross: alignS)
  setPaddingAll(world: world, entity: root, n: outerPad)

  let copiedId: String = ""
  copiedId = copiedId.concat(other: profilePageId)
  let pr: PageRoot = { id: own copiedId }
  componentSet(this: world.pageRoots, entity: root, data: own pr)

  let topBar: EntityId = buildPageTopBar(world: world, title: "Profile")
  let body: EntityId = buildProfileBody(world: world, reg: reg, state: state, scrollY: scrollY)

  let kids: List(EntityId) = createList(EntityId, cap: 2)
  kids.add(value: topBar)
  kids.add(value: body)
  attachChildren(world: world, parent: root, kids: kids)

  ret root
}

# Legacy single-screen entrypoint used by `buildScreenWorld` /
# `runScreenshotMode`. Mounts the profile page + shared dock + back
# overlays into a fresh world.
func buildProfileWorld(
  scenes: view AlbumScenes
  reg: view TextureRegistry
  state: view AppState
  playback: view PlaybackState
  scrollY: view Float
) pub ret UiWorld {
  let world: UiWorld = createUiWorld()
  let page: EntityId = mountProfilePage(world: world, reg: reg, state: state, scrollY: scrollY)
  let dock: EntityId = mountBottomDockOverlay(
    world: world
    activeTab: state.tab
    scenes: scenes
    playback: playback
    state: state
    reg: reg
  )
  let back: EntityId = mountBackButtonOverlay(world: world, state: state)
  ret world
}
