# Scratch output (snapshots, build artifacts, etc.). The example
# generates fresh PNGs into temp/screenshots on every snapshot run;
# keep them out of git so the diff stays readable.
temp/

# Per-user UI state — active album, track, playback position.
# Written by `playback_state_io.rae` after every action; would
# otherwise spam the diff and leak personal listening history.
assets/state.json
