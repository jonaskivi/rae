pack MobileUiGpu2d {
  format: "raepack"
  version: 1
  defaultTarget: compiled
  name: "Mobile UI — GPU2D"
  description: "GPU2D and SDL3-only port of the mobile music UI example."
  category: "UI"
  targets: {
    target compiled: {
      label: "Compiled"
      entry: "main.rae"
      sources: {
        source: { path: ".", emit: compiled }
      }
    }
  }
}
