let debugSwitchKnob: Float = 56.3855421686747
let debugSwitchKnobOffset: Float = 26.024096385542165
let debugPanelRadius: Float = 69.39759036144578
let debugPanelPadding: Float = 43.373493975903614
let debugPanelInset: Float = 86.74698795180723
let debugCloseIconSize: Float = 69.39759036144578
let debugCloseButtonW: Float = 312.289156626506
