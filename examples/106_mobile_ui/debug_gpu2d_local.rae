  attachKids(world: world, parent: title, kids: kids)
  ret title
}

func buildSwitchRow(
  world: mod UiWorld
  labelText: own String
  actionId: own String
  on: view Bool
  width: view Float
) ret EntityId {
  let row: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: row, w: width, h: debugRowH)
  setHorizontalLayout(world: world, entity: row, gap: debugRowGap, alignCross: AlignKind.center)
  # Data-oriented widget tags (#220): identity + on/off state + action
  # binding as queryable component data. Copies taken BEFORE
  # setOnClickAction consumes `actionId` (own param). The switch
  # visuals are still mount-baked — the debug menu re-mounts on every
  # toggle — but systems can now read which toggles exist and which
  # are on straight from the widgetStates table.
  let toggleKind: String = "debugToggle"
  setWidgetIdentity(world: world, entity: row, id: actionId, kind: toggleKind)
  setWidgetState(world: world, entity: row, enabled: true, selected: on, loading: false, error: false)
  let bindId: String = "{actionId}"
  let bindRole: String = "primary"
  let binding: ActionBinding = {
    actionId: own bindId
    role: own bindRole
  }
  componentSet(this: world.actionBindings, entity: row, data: own binding)
  setOnClickAction(world: world, entity: row, actionId: actionId)

  let label: EntityId = createEntity(world: world)
  let labelW: Float = width - debugSwitchW - debugRowGap
  setFixedRect(world: world, entity: label, w: labelW, h: debugLabelH)
  setDebugText(world: world, entity: label, text: labelText, styleId: "debugMenuLabel")

  let pill: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: pill, w: debugSwitchW, h: debugSwitchH)
  var pillFill: RgbaColor = debugSwitchOffColor()
  if on { pillFill = debugSwitchOnColor() }
  setRoundedShape(world: world, entity: pill, fill: pillFill, radius: debugSwitchRadius)
  setStackLayout(world: world, entity: pill)

  let knob: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: knob, w: debugSwitchKnob, h: debugSwitchKnob)
  setCircleShape(world: world, entity: knob, fill: debugSwitchKnobColor())
  var knobOff: Float = 0.0 - debugSwitchKnobOffset
  if on { knobOff = debugSwitchKnobOffset }
  setOffset(world: world, entity: knob, x: knobOff, y: 0.0)

  let pillKids: List(EntityId) = createList(EntityId, cap: 1)
  pillKids.add(value: knob)
  attachKids(world: world, parent: pill, kids: pillKids)

  let rowKids: List(EntityId) = createList(EntityId, cap: 2)
  rowKids.add(value: label)
  rowKids.add(value: pill)
  attachKids(world: world, parent: row, kids: rowKids)
  ret row
}

func buildDebugMenuOverlay(world: mod UiWorld, debug: view DebugSystem) ret EntityId {
  let backdrop: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: backdrop, w: debug.screenW, h: debug.screenH)
  setOffset(world: world, entity: backdrop, x: 0.0, y: 0.0)
  setRectShape(world: world, entity: backdrop, fill: debugBackdropColor())
  setOnClickAction(world: world, entity: backdrop, actionId: debugActionDismiss)
  setStackLayout(world: world, entity: backdrop)

  let panelW: Float = debug.screenW * 0.86
  let panelH: Float = debug.screenH * 0.72
  let panel: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: panel, w: panelW, h: panelH)
  setRoundedShape(world: world, entity: panel, fill: debugMenuFillColor(), radius: debugPanelRadius)
  setStackLayout(world: world, entity: panel)

  let content: EntityId = createEntity(world: world)
  let contentW: Float = panelW - debugPanelPadding * 2.0
  let contentH: Float = panelH - debugContentTop - debugPanelPadding * 2.0 - debugCloseButtonH
  setFixedRect(world: world, entity: content, w: contentW, h: contentH)
  setAlign(world: world, entity: content, x: AlignKind.start, y: AlignKind.start)
  setOffset(world: world, entity: content, x: debugPanelPadding, y: debugContentTop)
  setVerticalLayout(world: world, entity: content, gap: debugRowGap)

  let themeRow: EntityId = buildSwitchRow(world: world, labelText: "Dark theme", actionId: debugActionToggleTheme, on: currentTheme().mode is ThemeMode.dark, width: contentW)
  let labelsRow: EntityId = buildSwitchRow(world: world, labelText: "FPS / mem labels", actionId: debugActionToggleLabels, on: debug.showLabels, width: contentW)
  let outlinesRow: EntityId = buildSwitchRow(world: world, labelText: "Input outlines", actionId: debugActionToggleInputOutlines, on: debug.showInputOutlines, width: contentW)

  let rows: List(EntityId) = createList(EntityId, cap: 3)
  rows.add(value: themeRow)
  rows.add(value: labelsRow)
  rows.add(value: outlinesRow)
  attachKids(world: world, parent: content, kids: rows)

  let closeX: EntityId = buildDebugIconButton(world: world)
  setAlign(world: world, entity: closeX, x: AlignKind.end, y: AlignKind.start)
  setOffset(world: world, entity: closeX, x: 0.0 - debugPanelPadding, y: debugPanelPadding)

  let closeButton: EntityId = buildDebugCloseButton(world: world)
  setAlign(world: world, entity: closeButton, x: AlignKind.center, y: AlignKind.end)
  setOffset(world: world, entity: closeButton, x: 0.0, y: 0.0 - debugPanelPadding)

  let title: EntityId = buildDebugMenuTitle(world: world, panelW: panelW)

  let panelKids: List(EntityId) = createList(EntityId, cap: 4)
  panelKids.add(value: content)
  panelKids.add(value: title)
  panelKids.add(value: closeX)
  panelKids.add(value: closeButton)
  attachKids(world: world, parent: panel, kids: panelKids)

  let backdropKids: List(EntityId) = createList(EntityId, cap: 1)
  backdropKids.add(value: panel)
  attachKids(world: world, parent: backdrop, kids: backdropKids)
  ret backdrop
}

func applyDebugAnchor(world: view UiWorld, debug: mod DebugSystem) ret Bool {
  let anchors: view ComponentTable(DebugAnchor) => world.debugAnchors
  let n: Int = componentCount(this: anchors)
  var i: Int = 0
  loop i < n {
    let e: EntityId = componentEntityAt(this: anchors, i: i)
    if componentHas(this: world.rects, entity: e) {
      let r: Rect = componentGet(this: world.rects, entity: e)
      debug.buttonX = r.x
      debug.buttonY = r.y
      if r.w > 0.0 { debug.buttonSize = r.w }
      ret true
    }
    i = i + 1
  }
  ret false
}

func addDebugLayer(world: mod UiWorld, debug: mod DebugSystem) pub {
  let hasAnchor: Bool = applyDebugAnchor(world: world, debug: debug)
  let btn: EntityId = buildDebugButton(world: world, debug: debug)
  setLayerById(world: world, entity: btn, id: "debug")
  if debug.menuOpen {
    let menu: EntityId = buildDebugMenuOverlay(world: world, debug: debug)
    setLayerById(world: world, entity: menu, id: "debug")
  }
}

func dispatchDebugAction(input: view InputSystem, debug: mod DebugSystem) pub ret Bool {
  var changed: Bool = false
  let n: Int = input.events.length
  var i: Int = 0
  loop i < n {
    let ev: ActionEvent = rae_ext_rae_buf_get(buf: input.events.data, index: i)
    let actionId: String = ev.actionId
    if actionId.equals(other: debugActionToggleMenu) {
      debug.menuOpen = debug.menuOpen is false
      changed = true
    }
    if actionId.equals(other: debugActionDismiss) {
      if debug.menuOpen {
        debug.menuOpen = false
        changed = true
      }
    }
    if actionId.equals(other: debugActionToggleTheme) {
      let cur: Theme = currentTheme()
      if cur.mode is ThemeMode.dark {
        setActiveTheme(theme: lightTheme())
      } else {
        setActiveTheme(theme: darkTheme())
      }
      changed = true
    }
    if actionId.equals(other: debugActionToggleLabels) {
      debug.showLabels = debug.showLabels is false
      changed = true
    }
    if actionId.equals(other: debugActionToggleInputOutlines) {
      debug.showInputOutlines = debug.showInputOutlines is false
      changed = true
    }
    i = i + 1
  }
  ret changed
}

func formatMemMBGpu2d(kb: view Int) ret String {
  let tenths: Int = (kb * 10) / 1024
  let whole: Int = tenths / 10
  let frac: Int = tenths - whole * 10
  ret "{whole}.{frac} MB"
}

func formatFpsGpu2d(fps: view Float) ret String {
  var rounded: Int = (fps + 0.5).toInt()
  if rounded < 0 { rounded = 0 }
  ret "fps: {rounded}"
}

func drawDebugHeartbeatGpu2d(debug: mod DebugSystem, didRealWork: view Bool) {
  if didRealWork {
    debug.heartbeatX = debug.heartbeatX + 2.1686746987951806
    if debug.heartbeatX > debug.screenW { debug.heartbeatX = -8.674698795180722 }
  }
  gpu2d.drawBox(x: debug.heartbeatX, y: 0.0, w: 8.674698795180722, h: 8.674698795180722, radius: 0.0, fill: 0xFFFFBF00, borderWidth: 0.0, border: 0x00000000)
}

func drawDebugLabelsGpu2d(debug: view DebugSystem, font: view SdfFont) {
  let fpsText: String = formatFpsGpu2d(fps: debug.lastFps)
  let memText: String = "mem: {formatMemMBGpu2d(kb: debug.lastRssKb)}"
  let fontSize: Float = 30.361445783132528
  let lineH: Float = 34.69879518072289
  let gap: Float = 8.674698795180722
  let bottomEdge: Float = debug.buttonY + debug.buttonSize
  let fpsY: Float = bottomEdge + gap + fontSize
  let memY: Float = fpsY + lineH + 4.337349397590361
  let buttonCx: Float = debug.buttonX + debug.buttonSize * 0.5
  let screenCx: Float = debug.screenW * 0.5
  let rightAligned: Bool = buttonCx > screenCx
  var fpsX: Float = debug.buttonX
  var memX: Float = debug.buttonX
  if rightAligned {
    let rightEdge: Float = debug.buttonX + debug.buttonSize
    fpsX = rightEdge - fpsText.length().toFloat() * fontSize * 0.52
    memX = rightEdge - memText.length().toFloat() * fontSize * 0.52
  }
  let amber: Int = 0xFFFFBF00
  gpu2d_text.drawText(font: font, text: fpsText, x: fpsX, y: fpsY, sizePx: fontSize, color: amber)
  gpu2d_text.drawText(font: font, text: memText, x: memX, y: memY, sizePx: fontSize, color: amber)
  if debug.showInputOutlines {
    var lb: Int = 0
    if gpu2d.pointerDown() { lb = 1 }
    let btnText: String = "btn: {lb}"
    let btnY: Float = memY + lineH + 4.337349397590361
    var btnX: Float = debug.buttonX
    if rightAligned {
      let rightEdge: Float = debug.buttonX + debug.buttonSize
      btnX = rightEdge - btnText.length().toFloat() * fontSize * 0.52
    }
    gpu2d_text.drawText(font: font, text: btnText, x: btnX, y: btnY, sizePx: fontSize, color: amber)
  }
}

func updateAndRenderDebugOverlayGpu2d(debug: mod DebugSystem, now: view Float, didRealWork: view Bool, font: view SdfFont) pub {
  recordDebugFrame(debug: debug, now: now, didRealWork: didRealWork)
  if debug.showLabels {
    drawDebugLabelsGpu2d(debug: debug, font: font)
    drawDebugHeartbeatGpu2d(debug: debug, didRealWork: didRealWork)
  }
}
