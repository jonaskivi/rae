func debugAmberColor() ret RgbaColor { ret RgbaColor { r: 255, g: 191, b: 0, a: 255 } }
func debugBackdropColor() ret RgbaColor { ret RgbaColor { r: 0, g: 0, b: 0, a: 160 } }
func debugMenuFillColor() ret RgbaColor { ret RgbaColor { r: 24, g: 24, b: 28, a: 240 } }
func debugSwitchOnColor() ret RgbaColor { ret RgbaColor { r: 52, g: 199, b: 89, a: 255 } }
func debugSwitchOffColor() ret RgbaColor { ret RgbaColor { r: 120, g: 120, b: 128, a: 200 } }
func debugSwitchKnobColor() ret RgbaColor { ret RgbaColor { r: 255, g: 255, b: 255, a: 255 } }

type DebugSystem {
  menuOpen: Bool
  showLabels: Bool
  showInputOutlines: Bool
  buttonX: Float
  buttonY: Float
  buttonSize: Float
  screenW: Float
  screenH: Float
  fpsTimes: List(Float)
  fpsWindowSec: Float
  lastFps: Float
  lastRssKb: Int
  heartbeatX: Float
  hasBlur: Bool
}

func debugBlurBackdropKey() pub ret String { ret "debug.blurBackdrop" }
func setDebugHasBlur(debug: mod DebugSystem, value: view Bool) pub { debug.hasBlur = value }

func setDebugButtonTopRight(debug: mod DebugSystem, margin: view Float) pub {
  debug.buttonX = debug.screenW - debug.buttonSize - margin
  debug.buttonY = margin
}

func createDebugSystem() pub ret DebugSystem {
  ret DebugSystem {
    menuOpen: false
    showLabels: false
    showInputOutlines: false
    buttonX: 34.69879518072289
    buttonY: 34.69879518072289
    buttonSize: 47.71084337349397
    screenW: 1080.0
    screenH: 2280.0
    fpsTimes: createList(Float, cap: 256)
    fpsWindowSec: 3.0
    lastFps: 0.0
    lastRssKb: 0
    heartbeatX: 0.0
    hasBlur: false
  }
}

func setDebugScreenSize(debug: mod DebugSystem, w: view Float, h: view Float) pub {
  debug.screenW = w
  debug.screenH = h
  # Re-anchor the button to the top-right of the (possibly resized) extent.
  # buttonY doubles as the margin (setDebugButtonTopRight keeps them equal),
  # so the button follows a window resize instead of sticking at its boot X.
  debug.buttonX = w - debug.buttonSize - debug.buttonY
}

func setDebugButtonPosition(debug: mod DebugSystem, x: view Float, y: view Float) pub {
  debug.buttonX = x
  debug.buttonY = y
}

func pruneFpsBuffer(debug: mod DebugSystem) {
  let capN: Int = 16
  let times: mod List(Float) => debug.fpsTimes
  loop times.length > capN {
    times.remove(index: 0)
  }
}

func recordDebugFrame(debug: mod DebugSystem, now: view Float, didRealWork: view Bool) pub {
  if didRealWork {
    let times: mod List(Float) => debug.fpsTimes
    times.add(value: now)
    pruneFpsBuffer(debug: debug)
  }
  let n: Int = debug.fpsTimes.length
  var fps: Float = 0.0
  if n >= 2 {
    let oldest: Float = debug.fpsTimes.get(index: 0)
    let newest: Float = debug.fpsTimes.get(index: n - 1)
    let span: Float = newest - oldest
    if span > 0.0 {
      fps = (n - 1).toFloat() / span
    }
  }
  debug.lastFps = fps
  debug.lastRssKb = processRssKb()
}

func currentDebugFPS(debug: view DebugSystem) pub ret Float { ret debug.lastFps }

func setOffset(world: mod UiWorld, entity: view EntityId, x: view Float, y: view Float) {
  let off: Offset = { delta: Vec2 { x: x, y: y } }
  componentSet(this: world.offsets, entity: entity, data: off)
}

func setAlign(world: mod UiWorld, entity: view EntityId, x: AlignKind, y: AlignKind) {
  let a: Align = {
    x: x
    y: y
    hasX: true
    hasY: true
  }
  componentSet(this: world.aligns, entity: entity, data: a)
}

func setFixedRect(world: mod UiWorld, entity: view EntityId, w: view Float, h: view Float) {
  let r: Rect = { x: 0.0, y: 0.0, w: w, h: h }
  componentSet(this: world.rects, entity: entity, data: r)
  let s: Size = {
    w: SizeAxis { mode: SizeMode.fixed, min: -1, max: -1 }
    h: SizeAxis { mode: SizeMode.fixed, min: -1, max: -1 }
  }
  componentSet(this: world.sizes, entity: entity, data: s)
}

func setCircleShape(world: mod UiWorld, entity: view EntityId, fill: view RgbaColor) {
  let sh: Shape = {
    kind: ShapeKind.circle
    fill: fill
    stroke: RgbaColor { r: 0, g: 0, b: 0, a: 0 }
    strokeWidth: 0.0
    radius: 0.0
  }
  componentSet(this: world.shapes, entity: entity, data: sh)
}

func setRectShape(world: mod UiWorld, entity: view EntityId, fill: view RgbaColor) {
  let sh: Shape = {
    kind: ShapeKind.rect
    fill: fill
    stroke: RgbaColor { r: 0, g: 0, b: 0, a: 0 }
    strokeWidth: 0.0
    radius: 0.0
  }
  componentSet(this: world.shapes, entity: entity, data: sh)
}

func setRoundedShape(world: mod UiWorld, entity: view EntityId, fill: view RgbaColor, radius: view Float) {
  let sh: Shape = {
    kind: ShapeKind.roundedRect
    fill: fill
    stroke: RgbaColor { r: 0, g: 0, b: 0, a: 0 }
    strokeWidth: 0.0
    radius: radius
  }
  componentSet(this: world.shapes, entity: entity, data: sh)
}

func setDebugText(world: mod UiWorld, entity: view EntityId, text: own String, styleId: own String) {
  let t: Text = {
    text: text
    styleId: styleId
    wrapWidthMode: WrapWidthMode.none
  }
  componentSet(this: world.texts, entity: entity, data: t)
}

func setDebugSprite(world: mod UiWorld, entity: view EntityId, key: own String, tint: view RgbaColor) {
  let sp: Sprite = {
    textureKey: key
    tint: tint
    scaleMode: ScaleMode.fit
    tileScale: Vec2 { x: 1.0, y: 1.0 }
    nineSlice: Insets { l: 0.0, t: 0.0, r: 0.0, b: 0.0 }
    hasNineSlice: false
  }
  componentSet(this: world.sprites, entity: entity, data: sp)
}

func setOpticalAlign(world: mod UiWorld, entity: view EntityId, centerX: view Bool, centerY: view Bool, biasX: view Float, biasY: view Float) {
  let oa: OpticalAlign = {
    enabled: true
    centerX: centerX
    centerY: centerY
    bias: Vec2 { x: biasX, y: biasY }
  }
  componentSet(this: world.opticalAligns, entity: entity, data: oa)
}

func setOnClickAction(world: mod UiWorld, entity: view EntityId, actionId: own String) {
  let oc: OnClick = {
    actionId: actionId
    actionIdDouble: ""
    actionIdTriple: ""
    maxDelayMs: 250
  }
  componentSet(this: world.onClicks, entity: entity, data: oc)
}

func setStackLayout(world: mod UiWorld, entity: view EntityId) {
  let lay: Layout = {
    kind: LayoutType.stack
    gap: 0.0
    alignMain: AlignKind.center
    alignCross: AlignKind.center
    columns: 0
    rowGap: 0.0
    columnGap: 0.0
  }
  componentSet(this: world.layouts, entity: entity, data: lay)
}

func setVerticalLayout(world: mod UiWorld, entity: view EntityId, gap: view Float) {
  let lay: Layout = {
    kind: LayoutType.vertical
    gap: gap
    alignMain: AlignKind.start
    alignCross: AlignKind.stretch
    columns: 0
    rowGap: 0.0
    columnGap: 0.0
  }
  componentSet(this: world.layouts, entity: entity, data: lay)
}

func setHorizontalLayout(world: mod UiWorld, entity: view EntityId, gap: view Float, alignCross: AlignKind) {
  let lay: Layout = {
    kind: LayoutType.horizontal
    gap: gap
    alignMain: AlignKind.start
    alignCross: alignCross
    columns: 0
    rowGap: 0.0
    columnGap: 0.0
  }
  componentSet(this: world.layouts, entity: entity, data: lay)
}

func dbgSetPaddingAll(world: mod UiWorld, entity: view EntityId, n: view Float) {
  let pad: Padding = { insets: Insets { l: n, t: n, r: n, b: n } }
  componentSet(this: world.paddings, entity: entity, data: pad)
}

func attachKids(world: mod UiWorld, parent: view EntityId, kids: view List(EntityId)) {
  let kidsCopy: List(EntityId) = createList(EntityId, cap: kids.length)
  var i: Int = 0
  loop i < kids.length {
    let k: EntityId = rae_ext_rae_buf_get(buf: kids.data, index: i)
    kidsCopy.add(value: k)
    let pl: Parent = { parent: parent }
    componentSet(this: world.parents, entity: k, data: pl)
    i = i + 1
  }
  let ch: Children = { ids: own kidsCopy }
  componentSet(this: world.childrens, entity: parent, data: own ch)
}

func buildDebugButton(world: mod UiWorld, debug: view DebugSystem) ret EntityId {
  let btn: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: btn, w: debug.buttonSize, h: debug.buttonSize)
  setOffset(world: world, entity: btn, x: debug.buttonX, y: debug.buttonY)
  setCircleShape(world: world, entity: btn, fill: debugAmberColor())
  setStackLayout(world: world, entity: btn)
  setOnClickAction(world: world, entity: btn, actionId: debugActionToggleMenu)

  let label: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: label, w: debug.buttonSize, h: debugButtonTextH)
  setOpticalAlign(world: world, entity: label, centerX: true, centerY: true, biasX: 0.0 - debugBoldOffset / 2.0, biasY: 0.0)
  setDebugText(world: world, entity: label, text: "D", styleId: "debugButtonSmall")
  let labelBold: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: labelBold, w: debug.buttonSize, h: debugButtonTextH)
  setOpticalAlign(world: world, entity: labelBold, centerX: true, centerY: true, biasX: debugBoldOffset / 2.0, biasY: 0.0)
  setDebugText(world: world, entity: labelBold, text: "D", styleId: "debugButtonSmall")
  let kids: List(EntityId) = createList(EntityId, cap: 2)
  kids.add(value: label)
  kids.add(value: labelBold)
  attachKids(world: world, parent: btn, kids: kids)
  ret btn
}

func buildDebugIconButton(world: mod UiWorld) ret EntityId {
  let btn: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: btn, w: debugCloseIconSize, h: debugCloseIconSize)
  setRoundedShape(world: world, entity: btn, fill: themeColorByName(name: "outline"), radius: debugCloseIconSize / 2.0)
  setStackLayout(world: world, entity: btn)
  setOnClickAction(world: world, entity: btn, actionId: debugActionDismiss)

  let icon: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: icon, w: debugCloseIconGlyph, h: debugCloseIconGlyph)
  setOpticalAlign(world: world, entity: icon, centerX: true, centerY: true, biasX: 0.0, biasY: 0.0)
  setDebugSprite(world: world, entity: icon, key: "mat:close", tint: themeColorByName(name: "textPrimary"))
  let iconLeft: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: iconLeft, w: debugCloseIconGlyph, h: debugCloseIconGlyph)
  setOpticalAlign(world: world, entity: iconLeft, centerX: true, centerY: true, biasX: 0.0 - debugCloseIconBoldOffset, biasY: 0.0)
  setDebugSprite(world: world, entity: iconLeft, key: "mat:close", tint: themeColorByName(name: "textPrimary"))
  let iconRight: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: iconRight, w: debugCloseIconGlyph, h: debugCloseIconGlyph)
  setOpticalAlign(world: world, entity: iconRight, centerX: true, centerY: true, biasX: debugCloseIconBoldOffset, biasY: 0.0)
  setDebugSprite(world: world, entity: iconRight, key: "mat:close", tint: themeColorByName(name: "textPrimary"))
  let iconUp: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: iconUp, w: debugCloseIconGlyph, h: debugCloseIconGlyph)
  setOpticalAlign(world: world, entity: iconUp, centerX: true, centerY: true, biasX: 0.0, biasY: 0.0 - debugCloseIconBoldOffset)
  setDebugSprite(world: world, entity: iconUp, key: "mat:close", tint: themeColorByName(name: "textPrimary"))
  let iconDown: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: iconDown, w: debugCloseIconGlyph, h: debugCloseIconGlyph)
  setOpticalAlign(world: world, entity: iconDown, centerX: true, centerY: true, biasX: 0.0, biasY: debugCloseIconBoldOffset)
  setDebugSprite(world: world, entity: iconDown, key: "mat:close", tint: themeColorByName(name: "textPrimary"))
  let kids: List(EntityId) = createList(EntityId, cap: 5)
  kids.add(value: icon)
  kids.add(value: iconLeft)
  kids.add(value: iconRight)
  kids.add(value: iconUp)
  kids.add(value: iconDown)
  attachKids(world: world, parent: btn, kids: kids)
  ret btn
}

