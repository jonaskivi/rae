  let title: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: title, w: panelW, h: debugDialogTitleH)
  setAlign(world: world, entity: title, x: AlignKind.center, y: AlignKind.start)
  setOffset(world: world, entity: title, x: 0.0, y: debugDialogTitleY)
  setStackLayout(world: world, entity: title)

  let label: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: label, w: panelW, h: debugDialogTitleH)
  setOpticalAlign(world: world, entity: label, centerX: true, centerY: true, biasX: 0.0 - debugBoldOffset / 2.0, biasY: 0.0)
  setDebugText(world: world, entity: label, text: "Debug", styleId: "debugDialogTitle")
  let labelBold: EntityId = createEntity(world: world)
  setFixedRect(world: world, entity: labelBold, w: panelW, h: debugDialogTitleH)
  setOpticalAlign(world: world, entity: labelBold, centerX: true, centerY: true, biasX: debugBoldOffset / 2.0, biasY: 0.0)
