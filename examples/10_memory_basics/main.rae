type Point {
  x: Int
  y: Int
}

func main() {
  # 1. Value Type
  let p1: Point = { x: 10, y: 20 }
  # Copy
  let p2: Point = p1
  p2.x = 30
  # Prints 10
  log(p1.x)
  # 2. Borrow Type (mutable view)
  let r: mod Point => p1
  r.y = 50
  # Prints 50
  log(p1.y)
  # 3. Borrow Type (read-only view)
  let r2: view Point => p1
  log(r2.x)
}
