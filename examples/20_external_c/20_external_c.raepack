pack ExternalC {
  format: "raepack"
  version: 1
  defaultTarget: compiled
  name: "External C logic"
  description: "Demonstrates linking with external C functions."
  targets: {
    target compiled: {
      label: "Compiled"
      entry: "main.rae"
      sources: {
        source: { path: ".", emit: compiled }
      }
    }
  }
}
