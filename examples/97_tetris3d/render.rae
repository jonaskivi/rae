# 3D scene rendering: the locked board, the falling piece, particles,
# and a wireframe well frame so the play area is legible from any
# camera angle. Coordinates: x is column 0..gridWidth, y goes DOWN
# in grid space but is flipped to negative-Y in 3D so the well sits
# above the floor grid.
import raylib

# Convert (gridX, gridY) to world Vector3 centred on the cell.
func cellPos(gx: view Int, gy: view Int) ret Vector3 {
  let cx: Float = gx.toFloat() + 0.5
  let cy: Float = (0.0 - gy.toFloat()) - 0.5
  ret Vector3 { x: cx, y: cy, z: 0.0 }
}

func drawBlock(gx: view Int, gy: view Int, kindId: view Int, flash: view Float) {
  let pos: Vector3 = cellPos(gx: gx, gy: gy)
  let col: Color = kindColor(id: kindId)
  # Lock-flash: brighten colour briefly when a piece just locks.
  let mix: Int = (flash * 80.0).toInt()
  var r: Int = col.r + mix
  var g: Int = col.g + mix
  var b: Int = col.b + mix
  if r > 255 {
    r = 255
  }
  if g > 255 {
    g = 255
  }
  if b > 255 {
    b = 255
  }
  let lit: Color = { r: r, g: g, b: b, a: 255 }
  # Full-cell cube — adjacent cells of the same piece tile seamlessly.
  drawCube(pos: pos, width: 1.0, height: 1.0, length: 1.0, color: lit)
}

# Draw the grid lines of the play well, half a block behind the cubes
# (z = -0.5) so they sit on the back face of every cell — visible
# through empty cells, hidden behind locked / falling pieces.
func drawWell() {
  # Bind globals to locals so method-call dispatch picks the Int.toFloat()
  # overload instead of String.toFloat() (overload resolution doesn't see
  # global Ints as having a clear receiver type yet).
  let gw: Int = gridWidth
  let gh: Int = gridHeight
  let gwF: Float = gw.toFloat()
  let ghF: Float = gh.toFloat()
  let backZ: Float = 0.0 - 0.5

  var i: Int = 0
  loop i <= gh {
    let y: Float = 0.0 - i.toFloat()
    drawCubeWires(
      pos: Vector3 { x: gwF / 2.0, y: y, z: backZ }
      width: gwF
      height: 0.02
      length: 0.02
      color: { r: 80, g: 90, b: 110, a: 60 }
    )
    i = i + 1
  }
  var j: Int = 0
  loop j <= gw {
    let x: Float = j.toFloat()
    drawCubeWires(
      pos: Vector3 { x: x, y: 0.0 - ghF / 2.0, z: backZ }
      width: 0.02
      height: ghF
      length: 0.02
      color: { r: 80, g: 90, b: 110, a: 60 }
    )
    j = j + 1
  }
}

func drawLockedGrid(w: view World) {
  var y: Int = 0
  loop y < gridHeight {
    var x: Int = 0
    loop x < gridWidth {
      let v: Int = gridGet(w: w, x: x, y: y)
      if v > 0 {
        drawBlock(gx: x, gy: y, kindId: v, flash: w.lockFlash)
      }
      x = x + 1
    }
    y = y + 1
  }
}

func drawCurrentPiece(w: view World) {
  if w.state is GameState.gameOver {
    ret
  }
  let cp: view Piece => w.currentPiece
  let kindId: Int = getKindId(kind: cp.kind)
  var py: Int = 0
  loop py < 4 {
    var px: Int = 0
    loop px < 4 {
      if getShapeCell(kind: cp.kind, rot: cp.rotation, px: px, py: py) is 1 {
        drawBlock(gx: cp.x + px, gy: cp.y + py, kindId: kindId, flash: 0.0)
      }
      px = px + 1
    }
    py = py + 1
  }
}

# Ghost piece: faint outline of where the current piece will land.
func drawGhostPiece(w: view World) {
  if w.state is GameState.gameOver {
    ret
  }
  let cp: view Piece => w.currentPiece
  # Find drop distance.
  var drop: Int = 0
  loop canMove(w: w, dx: 0, dy: drop + 1, dr: 0) is 1 {
    drop = drop + 1
  }
  if drop is 0 {
    ret
  }
  var py: Int = 0
  loop py < 4 {
    var px: Int = 0
    loop px < 4 {
      if getShapeCell(kind: cp.kind, rot: cp.rotation, px: px, py: py) is 1 {
        let pos: Vector3 = cellPos(gx: cp.x + px, gy: cp.y + drop + py)
        drawCubeWires(
          pos: pos
          width: 1.0
          height: 1.0
          length: 1.0
          color: { r: 200, g: 200, b: 220, a: 60 }
        )
      }
      px = px + 1
    }
    py = py + 1
  }
}

func renderSystem(w: view World) {
  drawWell()
  drawLockedGrid(w)
  drawGhostPiece(w)
  drawCurrentPiece(w)
  renderParticles(w)
}
