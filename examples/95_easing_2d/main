RAE_UNUSED static double rae_easeInBack_rae_Float_(double t) {
  double c1 = 1.70158;
  double c3 = c1 + 1.0;
  double _ret = c3 * t * t * t - c1 * t * t;
  return _ret;
}

typedef struct {
  double t;
} _spawn_args_rae_easeInBack_rae_Float_;

static void* _spawn_wrapper_rae_easeInBack_rae_Float_(void* data) {
  _spawn_args_rae_easeInBack_rae_Float_* args = (_spawn_args_rae_easeInBack_rae_Float_*)data;
  rae_easeInBack_rae_Float_(args->t);
  free(args);
  return NULL;
}

RAE_UNUSED static double rae_easeOutBack_rae_Float_(double t) {
  double c1 = 1.70158;
  double c3 = c1 + 1.0;
  double _ret = 1.0 + c3 * rae_ext_rae_math_pow(t - 1.0, 3.0) + c1 * rae_ext_rae_math_pow(t - 1.0, 2.0);
  return _ret;
}

typedef struct {
  double t;
} _spawn_args_rae_easeOutBack_rae_Float_;

static void* _spawn_wrapper_rae_easeOutBack_rae_Float_(void* data) {
  _spawn_args_rae_easeOutBack_rae_Float_* args = (_spawn_args_rae_easeOutBack_rae_Float_*)data;
  rae_easeOutBack_rae_Float_(args->t);
  free(args);
  return NULL;
}

RAE_UNUSED static double rae_easeOutBounce_rae_Float_(double t) {
  double n1 = 7.5625;
  double d1 = 2.75;
  if (t < 1.0 / d1) {
  double _ret = n1 * t * t;
  return _ret;
  } else {
  if (t < 2.0 / d1) {
  t = t - 1.5 / d1;
  double _ret = n1 * t * t + 0.75;
  return _ret;
  } else {
  if (t < 2.5 / d1) {
  t = t - 2.25 / d1;
  double _ret = n1 * t * t + 0.9375;
  return _ret;
  } else {
  t = t - 2.625 / d1;
  double _ret = n1 * t * t + 0.984375;
  return _ret;
  }
  }
  }
}

typedef struct {
  double t;
} _spawn_args_rae_easeOutBounce_rae_Float_;

static void* _spawn_wrapper_rae_easeOutBounce_rae_Float_(void* data) {
  _spawn_args_rae_easeOutBounce_rae_Float_* args = (_spawn_args_rae_easeOutBounce_rae_Float_*)data;
  rae_easeOutBounce_rae_Float_(args->t);
  free(args);
  return NULL;
}

RAE_UNUSED static double rae_easeInBounce_rae_Float_(double t) {
  double _ret = 1.0 - rae_easeOutBounce_rae_Float_(1.0 - t);
  return _ret;
}

typedef struct {
  double t;
} _spawn_args_rae_easeInBounce_rae_Float_;

static void* _spawn_wrapper_rae_easeInBounce_rae_Float_(void* data) {
  _spawn_args_rae_easeInBounce_rae_Float_* args = (_spawn_args_rae_easeInBounce_rae_Float_*)data;
  rae_easeInBounce_rae_Float_(args->t);
  free(args);
  return NULL;
}

RAE_UNUSED static Timer rae_createTimer_(void) {
  Timer _ret = (Timer){ .startTime = 0, .accumulated = 0, .running = 0 };
  return _ret;
}

typedef struct {
} _spawn_args_rae_createTimer_;

static void* _spawn_wrapper_rae_createTimer_(void* data) {
  _spawn_args_rae_createTimer_* args = (_spawn_args_rae_createTimer_*)data;
  rae_createTimer_();
  free(args);
  return NULL;
}

RAE_UNUSED static void rae_start_rae_Timer_(Timer* t) {
  if (t->running) {
  return;
  }
  t->startTime = rae_ext_nowNs();
  t->running = 1;
}

typedef struct {
  Timer* t;
} _spawn_args_rae_start_rae_Timer_;

static void* _spawn_wrapper_rae_start_rae_Timer_(void* data) {
  _spawn_args_rae_start_rae_Timer_* args = (_spawn_args_rae_start_rae_Timer_*)data;
  rae_start_rae_Timer_(args->t);
  free(args);
  return NULL;
}

RAE_UNUSED static void rae_stop_rae_Timer_(Timer* t) {
  if (t->running == 0) {
  return;
  }
  int64_t now = rae_ext_nowNs();
  t->accumulated = t->accumulated + (now - t->startTime);
  t->running = 0;
}

typedef struct {
  Timer* t;
} _spawn_args_rae_stop_rae_Timer_;

static void* _spawn_wrapper_rae_stop_rae_Timer_(void* data) {
  _spawn_args_rae_stop_rae_Timer_* args = (_spawn_args_rae_stop_rae_Timer_*)data;
  rae_stop_rae_Timer_(args->t);
  free(args);
  return NULL;
}

RAE_UNUSED static void rae_reset_rae_Timer_(Timer* t) {
  t->startTime = 0;
  t->accumulated = 0;
  t->running = 0;
}

typedef struct {
  Timer* t;
} _spawn_args_rae_reset_rae_Timer_;

static void* _spawn_wrapper_rae_reset_rae_Timer_(void* data) {
  _spawn_args_rae_reset_rae_Timer_* args = (_spawn_args_rae_reset_rae_Timer_*)data;
  rae_reset_rae_Timer_(args->t);
  free(args);
  return NULL;
}

RAE_UNUSED static int64_t rae_elapsedNs_rae_Timer_(const Timer* t) {
  int64_t total = t->accumulated;
  if (t->running) {
  int64_t now = rae_ext_nowNs();
  int64_t _ret = total + (now - t->startTime);
  return _ret;
  }
  int64_t _ret = total;
  return _ret;
}

typedef struct {
  Timer* t;
} _spawn_args_rae_elapsedNs_rae_Timer_;

static void* _spawn_wrapper_rae_elapsedNs_rae_Timer_(void* data) {
  _spawn_args_rae_elapsedNs_rae_Timer_* args = (_spawn_args_rae_elapsedNs_rae_Timer_*)data;
  rae_elapsedNs_rae_Timer_(args->t);
  free(args);
  return NULL;
}

RAE_UNUSED static double rae_elapsedMs_rae_Timer_(const Timer* t) {
  int64_t ns = rae_elapsedNs_rae_Timer_(t);
  double _ret = rae_toFloat_rae_Int_(ns) / 1000000.0;
  return _ret;
}

typedef struct {
  Timer* t;
} _spawn_args_rae_elapsedMs_rae_Timer_;

static void* _spawn_wrapper_rae_elapsedMs_rae_Timer_(void* data) {
  _spawn_args_rae_elapsedMs_rae_Timer_* args = (_spawn_args_rae_elapsedMs_rae_Timer_*)data;
  rae_elapsedMs_rae_Timer_(args->t);
  free(args);
  return NULL;
}

RAE_UNUSED static double rae_elapsedSeconds_rae_Timer_(const Timer* t) {
  int64_t ns = rae_elapsedNs_rae_Timer_(t);
  double _ret = rae_toFloat_rae_Int_(ns) / 1000000000.0;
  return _ret;
}

typedef struct {
  Timer* t;
} _spawn_args_rae_elapsedSeconds_rae_Timer_;

static void* _spawn_wrapper_rae_elapsedSeconds_rae_Timer_(void* data) {
  _spawn_args_rae_elapsedSeconds_rae_Timer_* args = (_spawn_args_rae_elapsedSeconds_rae_Timer_*)data;
  rae_elapsedSeconds_rae_Timer_(args->t);
  free(args);
  return NULL;
}

int main(void) {
  rae_ext_initWindow(800, 450, "Rae Easing 2D");
  rae_ext_setTargetFPS(60);
  Timer timer = rae_createTimer_();
  double animDuration = 2.0;
  rae_start_rae_Timer_(&(timer));
  {
  while (rae_ext_windowShouldClose() == 0) {
  double elapsed = rae_elapsedSeconds_rae_Timer_(&(timer));
  if (elapsed > animDuration) {
  rae_reset_rae_Timer_(&(timer));
  rae_start_rae_Timer_(&(timer));
  elapsed = 0.0;
  }
  double t = elapsed / animDuration;
  double easedT = rae_easeInOutQuad_rae_Float_(t);
  double startX = 150.0;
  double endX = 650.0;
  double currentX = startX + (endX - startX) * easedT;
  double hue = t * 360.0;
  Color mainColor = rae_ext_colorFromHSV(hue, 0.6, 0.9);
  Color centerColor = rae_ext_colorFromHSV(hue, 0.3, 1.0);
  rae_ext_beginDrawing();
  rae_ext_drawRectangleGradientV(0, 0, 800, 450, (Color){ .r = 20, .g = 30, .b = 48, .a = 255 }, (Color){ .r = 36, .g = 59, .b = 85, .a = 255 });
  rae_ext_drawText("Easing: easeInOutQuad", 20.0, 20.0, 20.0, (Color){ .r = 150, .g = 150, .b = 180, .a = 255 });
  rae_ext_drawCircle(currentX + 5.0, 230.0, 45.0, (Color){ .r = 0, .g = 0, .b = 0, .a = 40 });
  rae_ext_drawCircleGradient(rae_toInt_rae_Float_(currentX), 225, 40.0, centerColor, mainColor);
  rae_ext_endDrawing();
  }
  }
  rae_ext_closeWindow();
  return 0;
}

