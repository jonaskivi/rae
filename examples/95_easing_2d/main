  _spawn_args_rae_randomFloat_rae_Float_rae_Float_* args = (_spawn_args_rae_randomFloat_rae_Float_rae_Float_*)data;
  rae_randomFloat_rae_Float_rae_Float_(args->min, args->max);
  free(args);
  return NULL;
}

