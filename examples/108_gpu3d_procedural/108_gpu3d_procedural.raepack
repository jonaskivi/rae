pack Gpu3dProcedural {
  format: "raepack"
  version: 1
  defaultTarget: compiled
  name: "3D Renderer — Procedural Scene — GPT-5.6-Sol"
  description: "Initial example authored by GPT-5.6-Sol. Interactive SDL3 + WebGPU 3D renderer seed with data-oriented scene components, procedural SDF geometry, noise, PBR-inspired shading, soft shadows, ambient occlusion, and supersampling."
  category: "3D Renderer"
  targets: {
    target compiled: {
      label: "Compiled"
      entry: "main.rae"
      sources: {
        source: { path: ".", emit: compiled }
      }
    }
  }
}
