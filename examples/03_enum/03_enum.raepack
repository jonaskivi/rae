pack Enum {
  format: "raepack"
  version: 1
  defaultTarget: live
  name: "Enums"
  description: "Basic enum definitions and usage in state management."
  targets: {
    target live: {
      label: "Live"
      entry: "main.rae"
      sources: {
        source: { path: ".", emit: live }
      }
    }
    target compiled: {
      label: "Compiled"
      entry: "main.rae"
      sources: {
        source: { path: ".", emit: compiled }
      }
    }
  }
}
