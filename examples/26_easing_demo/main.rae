import easing

func main() {
  log("Easing Demo (t from 0.0 to 1.0):")
  var i: Int = 0
  loop i <= 10 {
    let t: Float = i.toFloat() / 10.0
    let linear: Float = easing.easeLinear(t)
    let sineIn: Float = easing.easeInSine(t)
    let quadOut: Float = easing.easeOutQuad(t)
    let bounceOut: Float = easing.easeOutBounce(t)
    log("t: {t} -> Linear: {linear}, SineIn: {sineIn}, QuadOut: {quadOut}, BounceOut: {bounceOut}")
    i = i + 1
  }
}
